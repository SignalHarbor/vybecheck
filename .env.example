# WebSocket URL for frontend
# Local development:
VITE_WS_URL=ws://localhost:3000
VITE_SERVER_URL=http://localhost:3000

# Production (update after deploying to Fly.io):
# VITE_WS_URL=wss://vybecheck.fly.dev

# Question limits
VITE_DEFAULT_QUESTION_LIMIT=3
VITE_UPGRADED_QUESTION_LIMIT=10

# Additional host names allowed when parsing a pasted join URL.
# localhost/127.0.0.1 and the hosts in VITE_SERVER_URL / VITE_WS_URL / VITE_APP_URL
# are always allowed. Use this for extra allowed hosts (comma-separated).
# VITE_ALLOWED_JOIN_HOSTS=vybecheck.fly.dev,vybecheck.app

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...    # Your Starter Pack price ID
STRIPE_PRICE_PRO=price_...        # Your Pro Pack price ID
STRIPE_PRICE_ULTIMATE=price_...   # Your Ultimate Pack price ID
APP_URL=http://localhost:5173     # For redirects

# PostHog Analytics
# Get your project API key from https://app.posthog.com/project/settings
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://us.i.posthog.com   # or https://eu.i.posthog.com for EU cloud
POSTHOG_KEY=phc_...                           # server-side (same key, no VITE_ prefix)
POSTHOG_HOST=https://us.i.posthog.com
